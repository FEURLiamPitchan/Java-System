<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mycompany.javasystem.DocumentsController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #f4f4f4;"
            stylesheets="@style.css">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24;">
            <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
                <Circle radius="18" fill="#2d2d2d"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="Barangay San Isidro"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="Management System"
                           style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="🔔  Alerts"
                        style="-fx-background-color: #f4f4f4;
                               -fx-text-fill: #333333;
                               -fx-font-size: 12px;
                               -fx-background-radius: 20;
                               -fx-border-radius: 20;
                               -fx-border-color: #e0e0e0;
                               -fx-border-width: 1;
                               -fx-padding: 8 16;
                               -fx-cursor: hand;
                               -fx-focus-color: transparent;
                               -fx-faint-focus-color: transparent;"/>
                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: #f4f4f4;
                             -fx-background-radius: 20;
                             -fx-border-radius: 20;
                             -fx-border-color: #e0e0e0;
                             -fx-border-width: 1;
                             -fx-padding: 6 16;">
                    <Circle radius="14" fill="#2d2d2d"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label text="Administrator"
                               style="-fx-font-size: 12px; -fx-font-weight: bold;
                                      -fx-text-fill: #1a1a1a;"/>
                        <Label text="Admin"
                               style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>
                </HBox>
                <Button fx:id="logoutButton" text="← Logout" onAction="#handleLogout"
                        style="-fx-background-color: #ffffff;
                               -fx-text-fill: #555555;
                               -fx-font-size: 12px;
                               -fx-background-radius: 8;
                               -fx-border-radius: 8;
                               -fx-border-color: #e0e0e0;
                               -fx-border-width: 1;
                               -fx-padding: 8 16;
                               -fx-cursor: hand;
                               -fx-focus-color: transparent;
                               -fx-faint-focus-color: transparent;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
            <VBox fx:id="sidebarVBox" prefWidth="220" prefHeight="700"
                  style="-fx-background-color: #ffffff;
                         -fx-border-color: #e8e8e8;
                         -fx-border-width: 0 1 0 0;
                         -fx-padding: 20 12;">

                <Label text="MAIN"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

                <Button text="🏠   Dashboard" maxWidth="Infinity"
                        onAction="#goToDashboard"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #555555;
                               -fx-font-size: 13px;
                               -fx-background-radius: 8;
                               -fx-padding: 11 16;
                               -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand;
                               -fx-focus-color: transparent;
                               -fx-faint-focus-color: transparent;">
                    <VBox.margin><Insets bottom="4"/></VBox.margin>
                </Button>

                <Button text="👥   Residents" maxWidth="Infinity"
                        onAction="#goToResidents"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #555555;
                               -fx-font-size: 13px;
                               -fx-background-radius: 8;
                               -fx-padding: 11 16;
                               -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand;
                               -fx-focus-color: transparent;
                               -fx-faint-focus-color: transparent;">
                    <VBox.margin><Insets bottom="4"/></VBox.margin>
                </Button>

                <Button text="📄   Documents" maxWidth="Infinity"
                        style="-fx-background-color: #2d2d2d;
                               -fx-text-fill: #ffffff;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-padding: 11 16;
                               -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand;
                               -fx-focus-color: transparent;
                               -fx-faint-focus-color: transparent;">
                    <VBox.margin><Insets bottom="4"/></VBox.margin>
                </Button>

                <Button text="💳   Payments" maxWidth="Infinity"
                        onAction="#goToPayments" focusTraversable="false"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #555555;
                               -fx-font-size: 13px;
                               -fx-background-radius: 8;
                               -fx-padding: 11 16;
                               -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="4"/></VBox.margin>
                </Button>

                <Button text="    📁   Archive" maxWidth="Infinity"
                        onAction="#goToArchive" focusTraversable="false"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #777777;
                               -fx-font-size: 12px;
                               -fx-background-radius: 8;
                               -fx-padding: 9 16;
                               -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand;">
                    <VBox.margin><Insets bottom="16"/></VBox.margin>
                </Button>

                <Label text="COMMUNITY"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

                <Button text="📢   Complaints" maxWidth="Infinity"
                        onAction="#goToComplaints"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #555555;
                               -fx-font-size: 13px;
                               -fx-background-radius: 8;
                               -fx-padding: 11 16;
                               -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand;
                               -fx-focus-color: transparent;
                               -fx-faint-focus-color: transparent;">
                    <VBox.margin><Insets bottom="4"/></VBox.margin>
                </Button>

                <Button text="📣   Announcements" maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #555555;
                               -fx-font-size: 13px;
                               -fx-background-radius: 8;
                               -fx-padding: 11 16;
                               -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand;
                               -fx-focus-color: transparent;
                               -fx-faint-focus-color: transparent;">
                    <VBox.margin><Insets bottom="16"/></VBox.margin>
                </Button>

                <Label text="MANAGEMENT"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

                <Button text="📊   Finance" maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #555555;
                               -fx-font-size: 13px;
                               -fx-background-radius: 8;
                               -fx-padding: 11 16;
                               -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand;
                               -fx-focus-color: transparent;
                               -fx-faint-focus-color: transparent;">
                    <VBox.margin><Insets bottom="4"/></VBox.margin>
                </Button>

                <Button text="⚙️   Admin" maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #555555;
                               -fx-font-size: 13px;
                               -fx-background-radius: 8;
                               -fx-padding: 11 16;
                               -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand;
                               -fx-focus-color: transparent;
                               -fx-faint-focus-color: transparent;">
                    <VBox.margin><Insets bottom="4"/></VBox.margin>
                </Button>
            </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #f4f4f4;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Document Requests"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="Manage and process barangay document requests"
                           style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
            </HBox>

            <!-- Document Type Cards -->
            <HBox spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1;
                             -fx-padding: 20;">
                    <Label text="📋" style="-fx-font-size: 24px;"/>
                    <Label text="Barangay Clearance"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="For employment, bank, and legal purposes."
                           style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;
                                  -fx-wrap-text: true;"/>
                    <Label text="Processing: 1-2 business days"
                           style="-fx-font-size: 10px; -fx-text-fill: #888888;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1;
                             -fx-padding: 20;">
                    <Label text="🏠" style="-fx-font-size: 24px;"/>
                    <Label text="Certificate of Residency"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="Proof of residence in Barangay San Isidro."
                           style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;
                                  -fx-wrap-text: true;"/>
                    <Label text="Processing: Same day"
                           style="-fx-font-size: 10px; -fx-text-fill: #888888;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1;
                             -fx-padding: 20;">
                    <Label text="📄" style="-fx-font-size: 24px;"/>
                    <Label text="Certificate of Indigency"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="For medical, scholarship, and social assistance."
                           style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;
                                  -fx-wrap-text: true;"/>
                    <Label text="Processing: 1 business day"
                           style="-fx-font-size: 10px; -fx-text-fill: #888888;"/>
                </VBox>
            </HBox>

            <!-- Filter and Search bar -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <HBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1;
                             -fx-padding: 10 16;">
                    <Label text="🔍 "
                           style="-fx-font-size: 13px; -fx-text-fill: #aaaaaa;"/>
                    <TextField fx:id="searchField" promptText="Search by name or reference number..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: transparent;
                                      -fx-border-color: transparent;
                                      -fx-font-size: 13px;
                                      -fx-text-fill: #333333;"
                               onKeyReleased="#handleSearch"/>
                </HBox>
                <ComboBox fx:id="filterStatus" promptText="Filter by status"
                          onAction="#handleFilter"
                          style="-fx-background-color: #ffffff;
                                 -fx-border-color: #eeeeee;
                                 -fx-border-width: 1;
                                 -fx-border-radius: 10;
                                 -fx-background-radius: 10;
                                 -fx-font-size: 12px;
                                 -fx-padding: 4;"/>
                <ComboBox fx:id="filterType" promptText="Filter by type"
                          onAction="#handleFilter"
                          style="-fx-background-color: #ffffff;
                                 -fx-border-color: #eeeeee;
                                 -fx-border-width: 1;
                                 -fx-border-radius: 10;
                                 -fx-background-radius: 10;
                                 -fx-font-size: 12px;
                                 -fx-padding: 4;"/>
            </HBox>

            <!-- Table -->
            <VBox style="-fx-background-color: #ffffff;
                         -fx-background-radius: 10;
                         -fx-border-color: #eeeeee;
                         -fx-border-width: 1;">

                <!-- Table header -->
                <HBox style="-fx-padding: 14 16;
                             -fx-border-color: #f0f0f0;
                             -fx-border-width: 0 0 1 0;
                             -fx-background-color: #fafafa;
                             -fx-background-radius: 10 10 0 0;">
                    <Label text="REF #" prefWidth="125"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #aaaaaa;"/>
                    <Label text="RESIDENT" prefWidth="220"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #aaaaaa;"/>
                    <Label text="DOCUMENT TYPE" prefWidth="180"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #aaaaaa;"/>
                    <Label text="DATE FILED" prefWidth="150"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #aaaaaa;"/>
                    <Label text="STATUS" prefWidth="130"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #aaaaaa;"/>
                    <Label text="ACTION" prefWidth="200"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #aaaaaa;"/>
                </HBox>

                <!-- Table rows -->
                <VBox fx:id="documentsTableBody" style="-fx-padding: 0;">
                    <Label text="No document requests found."
                           style="-fx-font-size: 13px; -fx-text-fill: #aaaaaa;
                                  -fx-padding: 20 0;">
                        <VBox.margin><Insets top="20" bottom="20"/></VBox.margin>
                    </Label>
                </VBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>