<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mycompany.javasystem.AnnouncementsController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #f4f4f4;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65"       
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24;">

            <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
                <Circle radius="18" fill="#2d2d2d"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="Barangay San Isidro"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="Resident Portal"
                           style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: #f4f4f4;
                             -fx-background-radius: 20;
                             -fx-border-radius: 20;
                             -fx-border-color: #e0e0e0;
                             -fx-border-width: 1;
                             -fx-padding: 6 16;">
                    <Circle radius="14" fill="#2d2d2d"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label text="Resident Name"
                               style="-fx-font-size: 12px; -fx-font-weight: bold;
                                      -fx-text-fill: #1a1a1a;"/>
                        <Label text="Resident"
                               style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>
                </HBox>

                <Button fx:id="logoutButton" text="← Logout" onAction="#handleLogout"
                    style="-fx-background-color: #ffffff;
                        -fx-text-fill: #555555;
                        -fx-font-size: 12px;
                        -fx-background-radius: 8;
                        -fx-border-radius: 8;
                        -fx-border-color: #e0e0e0;
                        -fx-border-width: 1;
                        -fx-padding: 8 16;
                        -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="220" prefHeight="700"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 1 0 0;
                     -fx-padding: 20 12;">

            <Label text="MAIN"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="🏠   Dashboard" maxWidth="Infinity"
                    onAction="#goBackToDashboard"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📄   My Documents" maxWidth="Infinity"
                    onAction="#goToMyDocuments"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📝   Request Document" maxWidth="Infinity"
                    onAction="#goToRequestDocument"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="SERVICES"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="💳   Payments" maxWidth="Infinity"
                    onAction="#goToPayments"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📢   My Complaints" maxWidth="Infinity"
                    onAction="#goToComplaints"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📣   Announcements" maxWidth="Infinity"
                    style="-fx-background-color: #2d2d2d;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="ACCOUNT"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="👤   My Profile" maxWidth="Infinity"
                    onAction="#goToMyProfile"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #f4f4f4;
                           -fx-background: #f4f4f4;
                           -fx-border-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 24;">

                <!-- Page Header -->
                <VBox spacing="8">
                    <Label text="Announcements"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="Stay updated with the latest barangay news and announcements"
                           style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                </VBox>

                <!-- Announcements List -->
                <VBox spacing="16">

                    <!-- Urgent Announcement -->
                    <VBox style="-fx-background-color: #ffffff;
                                 -fx-background-radius: 10;
                                 -fx-border-color: #e53935;
                                 -fx-border-width: 2;
                                 -fx-padding: 24;"
                          spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="🚨"
                                   style="-fx-font-size: 20px;"/>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="URGENT: Typhoon Advisory – Signal No. 1"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold;
                                              -fx-text-fill: #e53935;"/>
                                <Label text="Today, 9:00 AM • Emergency Alert"
                                       style="-fx-font-size: 11px; -fx-text-fill: #e53935;"/>
                            </VBox>
                            <Label text="NEW"
                                   style="-fx-background-color: #e53935;
                                          -fx-text-fill: #ffffff;
                                          -fx-font-size: 10px;
                                          -fx-font-weight: bold;
                                          -fx-background-radius: 4;
                                          -fx-padding: 4 8;"/>
                        </HBox>
                        <Label text="Due to the approaching typhoon, all residents are advised to stay indoors and secure their properties. Emergency hotlines are available 24/7. Please monitor official channels for updates."
                               style="-fx-font-size: 13px; -fx-text-fill: #333333;"
                               wrapText="true"/>
                        <HBox spacing="8">
                            <Button text="📞 Emergency Contacts"
                                    style="-fx-background-color: #e53935;
                                           -fx-text-fill: #ffffff;
                                           -fx-font-size: 11px;
                                           -fx-background-radius: 6;
                                           -fx-padding: 6 12;
                                           -fx-cursor: hand;"/>
                            <Button text="📋 Safety Guidelines"
                                    style="-fx-background-color: #f4f4f4;
                                           -fx-text-fill: #555555;
                                           -fx-font-size: 11px;
                                           -fx-background-radius: 6;
                                           -fx-border-color: #e0e0e0;
                                           -fx-border-width: 1;
                                           -fx-border-radius: 6;
                                           -fx-padding: 6 12;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <!-- Regular Announcements -->
                    <VBox style="-fx-background-color: #ffffff;
                                 -fx-background-radius: 10;
                                 -fx-border-color: #eeeeee;
                                 -fx-border-width: 1;
                                 -fx-padding: 24;"
                          spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="💉"
                                   style="-fx-font-size: 20px;"/>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Free Vaccination Drive – June 15"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold;
                                              -fx-text-fill: #1a1a1a;"/>
                                <Label text="June 12 • Health Services"
                                       style="-fx-font-size: 11px; -fx-text-fill: #4caf50;"/>
                            </VBox>
                        </HBox>
                        <Label text="Free anti-flu vaccines will be available at the Barangay Health Center on June 15, 2024, from 8:00 AM to 5:00 PM. Please bring a valid ID and wear a face mask."
                               style="-fx-font-size: 13px; -fx-text-fill: #333333;"
                               wrapText="true"/>
                        <HBox spacing="8">
                            <Button text="📍 Location Details"
                                    style="-fx-background-color: #4caf50;
                                           -fx-text-fill: #ffffff;
                                           -fx-font-size: 11px;
                                           -fx-background-radius: 6;
                                           -fx-padding: 6 12;
                                           -fx-cursor: hand;"/>
                            <Button text="📅 Add to Calendar"
                                    style="-fx-background-color: #f4f4f4;
                                           -fx-text-fill: #555555;
                                           -fx-font-size: 11px;
                                           -fx-background-radius: 6;
                                           -fx-border-color: #e0e0e0;
                                           -fx-border-width: 1;
                                           -fx-border-radius: 6;
                                           -fx-padding: 6 12;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <VBox style="-fx-background-color: #ffffff;
                                 -fx-background-radius: 10;
                                 -fx-border-color: #eeeeee;
                                 -fx-border-width: 1;
                                 -fx-padding: 24;"
                          spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="🏛️"
                                   style="-fx-font-size: 20px;"/>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Monthly Barangay Assembly"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold;
                                              -fx-text-fill: #1a1a1a;"/>
                                <Label text="June 10 • Community Meeting"
                                       style="-fx-font-size: 11px; -fx-text-fill: #2196f3;"/>
                            </VBox>
                        </HBox>
                        <Label text="All residents are invited to attend the monthly barangay assembly on June 20, 2024, at 7:00 PM at the Barangay Hall. Topics include budget updates, new projects, and community concerns."
                               style="-fx-font-size: 13px; -fx-text-fill: #333333;"
                               wrapText="true"/>
                        <HBox spacing="8">
                            <Button text="📋 View Agenda"
                                    style="-fx-background-color: #2196f3;
                                           -fx-text-fill: #ffffff;
                                           -fx-font-size: 11px;
                                           -fx-background-radius: 6;
                                           -fx-padding: 6 12;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <VBox style="-fx-background-color: #ffffff;
                                 -fx-background-radius: 10;
                                 -fx-border-color: #eeeeee;
                                 -fx-border-width: 1;
                                 -fx-padding: 24;"
                          spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="🚧"
                                   style="-fx-font-size: 20px;"/>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Road Maintenance Schedule"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold;
                                              -fx-text-fill: #1a1a1a;"/>
                                <Label text="June 8 • Infrastructure"
                                       style="-fx-font-size: 11px; -fx-text-fill: #ff9800;"/>
                            </VBox>
                        </HBox>
                        <Label text="Road maintenance work will be conducted on Main Street from June 18-20, 2024. Expect traffic delays and use alternate routes. Work hours: 6:00 AM to 6:00 PM."
                               style="-fx-font-size: 13px; -fx-text-fill: #333333;"
                               wrapText="true"/>
                        <HBox spacing="8">
                            <Button text="🗺️ Alternate Routes"
                                    style="-fx-background-color: #ff9800;
                                           -fx-text-fill: #ffffff;
                                           -fx-font-size: 11px;
                                           -fx-background-radius: 6;
                                           -fx-padding: 6 12;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>