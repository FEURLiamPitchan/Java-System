<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mycompany.javasystem.ViewComplaintController"
      prefWidth="580"
      style="-fx-background-color: #f8f8f8;">

    <!-- Dark Header Bar -->
    <VBox style="-fx-background-color: #2d2d2d; -fx-padding: 24 28;">
        <HBox alignment="CENTER_LEFT">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Complaint Details"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;
                              -fx-text-fill: #ffffff;"/>
                <Label fx:id="complaintIdLabel"
                       style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
            </VBox>
            <Button text="✕" onAction="#handleClose"
                    style="-fx-background-color: #444444;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 12px;
                           -fx-background-radius: 6;
                           -fx-padding: 6 10;
                           -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- Form Body -->
    <VBox spacing="12" style="-fx-padding: 24 28 8 28;">

        <!-- Row 1: Complainant + Incident Type -->
        <HBox spacing="12">
            <VBox HBox.hgrow="ALWAYS" spacing="3"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 8;
                         -fx-border-color: #e0e0e0;
                         -fx-border-width: 1;
                         -fx-border-radius: 8;
                         -fx-padding: 14 16;">
                <Label text="COMPLAINANT"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #999999;"/>
                <Label fx:id="nameLabel"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: #1a1a1a;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="3"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 8;
                         -fx-border-color: #e0e0e0;
                         -fx-border-width: 1;
                         -fx-border-radius: 8;
                         -fx-padding: 14 16;">
                <Label text="INCIDENT TYPE"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #999999;"/>
                <Label fx:id="typeLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #1a1a1a;"/>
            </VBox>
        </HBox>

        <!-- Row 2: Location + Date Filed -->
        <HBox spacing="12">
            <VBox HBox.hgrow="ALWAYS" spacing="3"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 8;
                         -fx-border-color: #e0e0e0;
                         -fx-border-width: 1;
                         -fx-border-radius: 8;
                         -fx-padding: 14 16;">
                <Label text="LOCATION"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #999999;"/>
                <Label fx:id="locationLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #1a1a1a;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="3"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 8;
                         -fx-border-color: #e0e0e0;
                         -fx-border-width: 1;
                         -fx-border-radius: 8;
                         -fx-padding: 14 16;">
                <Label text="DATE FILED"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #999999;"/>
                <Label fx:id="dateLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #1a1a1a;"/>
            </VBox>
        </HBox>

        <!-- Incident Details -->
        <VBox spacing="6"
              style="-fx-background-color: #ffffff;
                     -fx-background-radius: 8;
                     -fx-border-color: #e0e0e0;
                     -fx-border-width: 1;
                     -fx-border-radius: 8;
                     -fx-padding: 14 16;">
            <Label text="INCIDENT DETAILS"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #999999;"/>
            <Label fx:id="detailsLabel"
                   style="-fx-font-size: 13px; -fx-text-fill: #1a1a1a;"
                   wrapText="true"/>
        </VBox>

        <!-- Photo Evidence -->
        <VBox spacing="6"
              style="-fx-background-color: #ffffff;
                     -fx-background-radius: 8;
                     -fx-border-color: #e0e0e0;
                     -fx-border-width: 1;
                     -fx-border-radius: 8;
                     -fx-padding: 14 16;">
            <Label text="PHOTO EVIDENCE"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #999999;"/>
            <Label fx:id="photoLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #555555;"
                   wrapText="true"/>
        </VBox>

        <!-- Status Update -->
        <VBox spacing="6"
              style="-fx-background-color: #ffffff;
                     -fx-background-radius: 8;
                     -fx-border-color: #e0e0e0;
                     -fx-border-width: 1;
                     -fx-border-radius: 8;
                     -fx-padding: 14 16;">
            <Label text="UPDATE STATUS"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #999999;"/>
            <ComboBox fx:id="statusCombo" maxWidth="Infinity"
                      style="-fx-font-size: 13px;
                             -fx-background-color: #f8f8f8;
                             -fx-background-radius: 6;
                             -fx-border-radius: 6;
                             -fx-border-color: #e0e0e0;
                             -fx-border-width: 1;
                             -fx-padding: 4;"/>
        </VBox>

        <!-- Admin Response -->
        <VBox spacing="6"
              style="-fx-background-color: #ffffff;
                     -fx-background-radius: 8;
                     -fx-border-color: #e0e0e0;
                     -fx-border-width: 1;
                     -fx-border-radius: 8;
                     -fx-padding: 14 16;">
            <Label text="ADMIN RESPONSE"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #999999;"/>
            <TextArea fx:id="responseArea"
                      promptText="Write your response to this complaint..."
                      prefHeight="90"
                      wrapText="true"
                      style="-fx-background-color: #f8f8f8;
                             -fx-border-color: #e0e0e0;
                             -fx-border-width: 1;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-font-size: 13px;
                             -fx-padding: 10;"/>
        </VBox>

    </VBox>

    <!-- Footer Buttons -->
    <HBox spacing="12" alignment="CENTER_RIGHT"
          style="-fx-padding: 16 28 24 28;
                 -fx-border-color: #eeeeee;
                 -fx-border-width: 1 0 0 0;
                 -fx-background-color: #ffffff;">
        <Button text="Close" onAction="#handleClose"
                style="-fx-background-color: #ffffff;
                       -fx-text-fill: #555555;
                       -fx-font-size: 13px;
                       -fx-background-radius: 8;
                       -fx-border-radius: 8;
                       -fx-border-color: #e0e0e0;
                       -fx-border-width: 1;
                       -fx-padding: 11 24;
                       -fx-cursor: hand;"/>
        <Button text="Save Changes" onAction="#handleSave"
                style="-fx-background-color: #2d2d2d;
                       -fx-text-fill: #ffffff;
                       -fx-font-size: 13px;
                       -fx-background-radius: 8;
                       -fx-padding: 11 24;
                       -fx-cursor: hand;"/>
    </HBox>

</VBox>