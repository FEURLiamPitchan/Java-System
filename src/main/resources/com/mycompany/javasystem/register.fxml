<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.mycompany.javasystem.RegisterController"
           prefHeight="600.0" prefWidth="900.0"
           style="-fx-background-color: linear-gradient(to bottom right, #1a1a1a, #2d2d2d, #1a1a1a);
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.9), 60, 0, 0, 20);">

    <HBox alignment="CENTER" spacing="0">
        <HBox.margin><Insets top="55" bottom="55" left="90" right="90"/></HBox.margin>

        <!-- LEFT PANEL -->
        <VBox alignment="CENTER" prefWidth="380" prefHeight="460"
              style="-fx-background-color: rgba(33,33,33,0.75);
                     -fx-background-radius: 20 0 0 20;
                     -fx-padding: 50;">

            <HBox spacing="8" alignment="CENTER">
                <Circle radius="4" fill="#444444"/>
                <Circle radius="4" fill="#555555"/>
                <Circle radius="4" fill="#666666"/>
            </HBox>
            <VBox.margin><Insets top="0" bottom="32"/></VBox.margin>

            <Label text="Barangay San Isidro"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;
                          -fx-text-fill: #ffffff; -fx-text-alignment: center;"
                   textAlignment="CENTER">
                <VBox.margin><Insets bottom="10"/></VBox.margin>
            </Label>

            <Label text="Management System"
                   style="-fx-font-size: 13px; -fx-text-fill: #555555;
                          -fx-text-alignment: center;"
                   textAlignment="CENTER">
                <VBox.margin><Insets bottom="24"/></VBox.margin>
            </Label>

            <HBox alignment="CENTER">
                <VBox.margin><Insets top="10" bottom="24"/></VBox.margin>
                <Rectangle width="50" height="2" arcWidth="2" arcHeight="2" fill="#444444"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER">
                <Label text="Efficient"
                       style="-fx-background-color: rgba(42,42,42,0.8);
                              -fx-background-radius: 20;
                              -fx-border-color: #383838;
                              -fx-border-width: 1;
                              -fx-border-radius: 20;
                              -fx-padding: 6 14;
                              -fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
                <Label text="Reliable"
                       style="-fx-background-color: rgba(42,42,42,0.8);
                              -fx-background-radius: 20;
                              -fx-border-color: #383838;
                              -fx-border-width: 1;
                              -fx-border-radius: 20;
                              -fx-padding: 6 14;
                              -fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
                <Label text="Modern"
                       style="-fx-background-color: rgba(42,42,42,0.8);
                              -fx-background-radius: 20;
                              -fx-border-color: #383838;
                              -fx-border-width: 1;
                              -fx-border-radius: 20;
                              -fx-padding: 6 14;
                              -fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </HBox>
            <VBox.margin><Insets top="0" bottom="28"/></VBox.margin>

           <Label text="Serving the community with&#10;transparency and efficiency."
                style="-fx-font-size: 11px; -fx-text-fill: #404040;
                -fx-text-alignment: center;"
                textAlignment="CENTER">
            <VBox.margin><Insets top="16"/></VBox.margin>
           </Label>

        </VBox>

        <!-- RIGHT PANEL -->
        <VBox alignment="CENTER" prefWidth="400" prefHeight="500"
              style="-fx-background-color: rgba(38,38,38,0.75);
                     -fx-background-radius: 0 20 20 0;
                     -fx-padding: 50;">

            <Rectangle width="40" height="4" arcWidth="4" arcHeight="4" fill="#555555">
                <VBox.margin><Insets bottom="24"/></VBox.margin>
            </Rectangle>

            <Label text="CREATE ACCOUNT"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-text-fill: #ffffff;">
                <VBox.margin><Insets bottom="6"/></VBox.margin>
            </Label>

            <Label text="Register to get started"
                   style="-fx-font-size: 12px; -fx-text-fill: #555555;">
                <VBox.margin><Insets bottom="28"/></VBox.margin>
            </Label>

            <TextField fx:id="emailField" promptText="Email Address"
                       maxWidth="Infinity"
                       style="-fx-background-color: rgba(46,46,46,0.9);
                              -fx-background-radius: 10;
                              -fx-border-radius: 10;
                              -fx-border-color: #383838;
                              -fx-border-width: 1;
                              -fx-padding: 13 18;
                              -fx-font-size: 13px;
                              -fx-text-fill: #ffffff;
                              -fx-prompt-text-fill: #4a4a4a;">
                <VBox.margin><Insets bottom="12"/></VBox.margin>
            </TextField>

            <PasswordField fx:id="passwordField" promptText="Password"
                           maxWidth="Infinity"
                           style="-fx-background-color: rgba(46,46,46,0.9);
                                  -fx-background-radius: 10;
                                  -fx-border-radius: 10;
                                  -fx-border-color: #383838;
                                  -fx-border-width: 1;
                                  -fx-padding: 13 18;
                                  -fx-font-size: 13px;
                                  -fx-text-fill: #ffffff;
                                  -fx-prompt-text-fill: #4a4a4a;">
                <VBox.margin><Insets bottom="12"/></VBox.margin>
            </PasswordField>

            <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password"
                           maxWidth="Infinity"
                           style="-fx-background-color: rgba(46,46,46,0.9);
                                  -fx-background-radius: 10;
                                  -fx-border-radius: 10;
                                  -fx-border-color: #383838;
                                  -fx-border-width: 1;
                                  -fx-padding: 13 18;
                                  -fx-font-size: 13px;
                                  -fx-text-fill: #ffffff;
                                  -fx-prompt-text-fill: #4a4a4a;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </PasswordField>

            <Label fx:id="messageLabel" text=""
                   style="-fx-font-size: 11px;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </Label>

            <Button text="Create Account" onAction="#handleRegister"
                    maxWidth="Infinity"
                    style="-fx-background-color: rgba(56,56,56,0.9);
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           -fx-border-color: #484848;
                           -fx-border-width: 1;
                           -fx-padding: 13 0;
                           -fx-cursor: hand;">
                <VBox.margin><Insets top="8" bottom="20"/></VBox.margin>
            </Button>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Already have an account?"
                       style="-fx-font-size: 12px; -fx-text-fill: #4a4a4a;"/>
                <Hyperlink text="Sign in here" onAction="#goToLogin"
                           style="-fx-text-fill: #888888; -fx-font-size: 12px;
                                  -fx-border-color: transparent;"/>
            </HBox>

        </VBox>
    </HBox>
</StackPane>