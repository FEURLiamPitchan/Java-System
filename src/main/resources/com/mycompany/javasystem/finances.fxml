<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mycompany.javasystem.FinancesController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #f0f2f5;"
            stylesheets="@style.css">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24;">
            <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
                <Circle radius="18" fill="#2d2d2d"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="Barangay San Isidro"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                    <Label text="Management System"
                           style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: #f4f4f4;
                             -fx-background-radius: 20; -fx-border-radius: 20;
                             -fx-border-color: #e0e0e0; -fx-border-width: 1;
                             -fx-padding: 6 16;">
                    <Circle radius="14" fill="#2d2d2d"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label text="Administrator"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                        <Label text="Admin"
                               style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>
                </HBox>
                <Button fx:id="logoutButton" text="← Logout" onAction="#handleLogout"
                        style="-fx-background-color: #ffffff; -fx-text-fill: #555555;
                               -fx-font-size: 12px; -fx-background-radius: 8;
                               -fx-border-radius: 8; -fx-border-color: #e0e0e0;
                               -fx-border-width: 1; -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="220" prefHeight="700"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 1 0 0;
                     -fx-padding: 20 12;">

            <Label text="MAIN"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>
            <Button text="🏠   Dashboard" maxWidth="Infinity" onAction="#goToDashboard"
                    focusTraversable="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #555555;
                           -fx-font-size: 13px; -fx-background-radius: 8;
                           -fx-padding: 11 16; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>
            <Button text="👥   Residents" maxWidth="Infinity" onAction="#goToResidents"
                    focusTraversable="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #555555;
                           -fx-font-size: 13px; -fx-background-radius: 8;
                           -fx-padding: 11 16; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>
            <Button text="📄   Documents" maxWidth="Infinity" onAction="#goToDocuments"
                    focusTraversable="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #555555;
                           -fx-font-size: 13px; -fx-background-radius: 8;
                           -fx-padding: 11 16; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>
            <Button text="💳   Payments" maxWidth="Infinity" onAction="#goToPayments"
                    focusTraversable="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #555555;
                           -fx-font-size: 13px; -fx-background-radius: 8;
                           -fx-padding: 11 16; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>
            <Button text="    📁   Archive" maxWidth="Infinity" onAction="#goToArchive"
                    focusTraversable="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #777777;
                           -fx-font-size: 12px; -fx-background-radius: 8;
                           -fx-padding: 9 16; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="COMMUNITY"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>
            <Button text="📢   Complaints" maxWidth="Infinity" onAction="#goToComplaints"
                    focusTraversable="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #555555;
                           -fx-font-size: 13px; -fx-background-radius: 8;
                           -fx-padding: 11 16; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>
            <Button text="📣   Announcements" maxWidth="Infinity" onAction="#goToAnnouncements"
                    focusTraversable="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #555555;
                           -fx-font-size: 13px; -fx-background-radius: 8;
                           -fx-padding: 11 16; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="MANAGEMENT"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>
            <Button text="📊   Finance" maxWidth="Infinity" focusTraversable="false"
                    style="-fx-background-color: #2d2d2d; -fx-text-fill: #ffffff;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>
            <Button text="⚙️   Admin" maxWidth="Infinity" focusTraversable="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #555555;
                           -fx-font-size: 13px; -fx-background-radius: 8;
                           -fx-padding: 11 16; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fx:id="mainScrollPane" fitToWidth="true"
                    style="-fx-background-color: transparent;
                           -fx-background: #f0f2f5;
                           -fx-border-color: transparent;">
            <VBox spacing="22" style="-fx-padding: 32; -fx-background-color: #f0f2f5;">

                <!-- Page Header -->
                <HBox alignment="CENTER_LEFT">
                    <VBox HBox.hgrow="ALWAYS" spacing="5">
                        <Label text="Financial Overview"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                        <Label text="Monitor barangay income, expenses, and financial trends"
                               style="-fx-font-size: 12px; -fx-text-fill: #999999;"/>
                    </VBox>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="＋  Add Expense" onAction="#handleAddExpense"
                                style="-fx-background-color: #2d2d2d; -fx-text-fill: #ffffff;
                                       -fx-font-size: 12px; -fx-font-weight: bold;
                                       -fx-background-radius: 8; -fx-padding: 11 22; -fx-cursor: hand;"/>
                        <Button text="⬇  Export CSV" onAction="#handleExportCSV"
                                style="-fx-background-color: #ffffff; -fx-text-fill: #555555;
                                       -fx-font-size: 12px; -fx-background-radius: 8;
                                       -fx-border-color: #dddddd; -fx-border-width: 1;
                                       -fx-padding: 11 22; -fx-cursor: hand;"/>
                    </HBox>
                </HBox>

                <!-- Summary Cards -->
                <HBox spacing="16">
                    <VBox HBox.hgrow="ALWAYS" spacing="12"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane style="-fx-background-color: #e8f5e9;
                                              -fx-background-radius: 10; -fx-padding: 10;">
                                <Label text="💰" style="-fx-font-size: 16px;"/>
                            </StackPane>
                            <Label text="TOTAL COLLECTIONS"
                                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #bbbbbb;"/>
                        </HBox>
                        <Label fx:id="totalCollectionsLabel" text="₱0.00"
                               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Circle radius="4" fill="#4caf50"/>
                            <Label text="All paid income"
                                   style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                        </HBox>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" spacing="12"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane style="-fx-background-color: #ffebee;
                                              -fx-background-radius: 10; -fx-padding: 10;">
                                <Label text="📉" style="-fx-font-size: 16px;"/>
                            </StackPane>
                            <Label text="TOTAL EXPENSES"
                                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #bbbbbb;"/>
                        </HBox>
                        <Label fx:id="totalExpensesLabel" text="₱0.00"
                               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Circle radius="4" fill="#e53935"/>
                            <Label text="All recorded expenses"
                                   style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                        </HBox>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" spacing="12"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane style="-fx-background-color: #e3f2fd;
                                              -fx-background-radius: 10; -fx-padding: 10;">
                                <Label text="⚖️" style="-fx-font-size: 16px;"/>
                            </StackPane>
                            <Label text="NET BALANCE"
                                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #bbbbbb;"/>
                        </HBox>
                        <Label fx:id="netBalanceLabel" text="₱0.00"
                               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Circle radius="4" fill="#1e88e5"/>
                            <Label text="Collections minus expenses"
                                   style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                        </HBox>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" spacing="12"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane style="-fx-background-color: #fff8e1;
                                              -fx-background-radius: 10; -fx-padding: 10;">
                                <Label text="⏳" style="-fx-font-size: 16px;"/>
                            </StackPane>
                            <Label text="PENDING PAYMENTS"
                                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #bbbbbb;"/>
                        </HBox>
                        <Label fx:id="pendingLabel" text="0"
                               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Circle radius="4" fill="#f59e0b"/>
                            <Label text="Awaiting payment"
                                   style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Charts Row -->
                <HBox spacing="16">
                    <VBox HBox.hgrow="ALWAYS" spacing="14"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <VBox spacing="4">
                            <Label text="Monthly Overview"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                            <Label text="Income vs Expenses — hover bars for details"
                                   style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                        </VBox>
                            <BarChart fx:id="barChart" prefHeight="260" animated="false"
                                      cache="true" cacheHint="SPEED"
                                      style="-fx-background-color: transparent;
                                             -fx-border-color: transparent;
                                             -fx-padding: 0; -fx-background-insets: 0;">
                            <xAxis>
                                <CategoryAxis style="-fx-tick-label-fill: #999999; -fx-font-size: 11px;"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis style="-fx-tick-label-fill: #999999; -fx-font-size: 11px;"/>
                            </yAxis>
                        </BarChart>
                    </VBox>

                    <VBox prefWidth="310" spacing="14"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <VBox spacing="4">
                            <Label text="Income Breakdown"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                            <Label text="By document type — hover for amounts"
                                   style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                        </VBox>
                            <PieChart fx:id="pieChart" prefHeight="260"
                                      animated="false" legendVisible="true" labelsVisible="false"
                                      cache="true" cacheHint="SPEED"
                                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                    </VBox>
                </HBox>

                <!-- Transaction Ledger -->
                <VBox spacing="18" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 16;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);
                             -fx-padding: 28;">

                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS" spacing="4">
                            <Label text="Transaction Ledger"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                            <Label text="All income and expense records"
                                   style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                        </VBox>
                        <Label fx:id="recordCountLabel" text="0 records"
                               style="-fx-font-size: 11px; -fx-text-fill: #888888;
                                      -fx-background-color: #f4f4f4;
                                      -fx-background-radius: 20; -fx-padding: 5 14;"/>
                    </HBox>

                    <!-- Filters -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <HBox HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #f8f9fa; -fx-background-radius: 10;
                                     -fx-border-color: #ebebeb; -fx-border-width: 1;
                                     -fx-border-radius: 10; -fx-padding: 10 16;">
                            <Label text="🔍  " style="-fx-font-size: 13px; -fx-text-fill: #cccccc;"/>
                            <TextField fx:id="searchField"
                                       promptText="Search by resident name or description..."
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: transparent;
                                              -fx-border-color: transparent;
                                              -fx-font-size: 13px; -fx-text-fill: #333333;"
                                       onKeyReleased="#handleSearch"/>
                        </HBox>
                        <ComboBox fx:id="filterType" promptText="Type"
                                  onAction="#handleFilter" prefWidth="120"
                                  style="-fx-background-color: #f8f9fa; -fx-border-color: #ebebeb;
                                         -fx-border-width: 1; -fx-border-radius: 10;
                                         -fx-background-radius: 10; -fx-font-size: 12px; -fx-padding: 5;"/>
                        <ComboBox fx:id="filterStatus" promptText="Status"
                                  onAction="#handleFilter" prefWidth="120"
                                  style="-fx-background-color: #f8f9fa; -fx-border-color: #ebebeb;
                                         -fx-border-width: 1; -fx-border-radius: 10;
                                         -fx-background-radius: 10; -fx-font-size: 12px; -fx-padding: 5;"/>
                        <DatePicker fx:id="filterDateFrom" promptText="From"
                                    onAction="#handleFilter" prefWidth="135"
                                    style="-fx-background-color: #f8f9fa; -fx-border-color: #ebebeb;
                                           -fx-border-width: 1; -fx-border-radius: 10;
                                           -fx-background-radius: 10; -fx-font-size: 12px;"/>
                        <DatePicker fx:id="filterDateTo" promptText="To"
                                    onAction="#handleFilter" prefWidth="135"
                                    style="-fx-background-color: #f8f9fa; -fx-border-color: #ebebeb;
                                           -fx-border-width: 1; -fx-border-radius: 10;
                                           -fx-background-radius: 10; -fx-font-size: 12px;"/>
                        <Button text="✕  Clear" onAction="#handleClearFilters"
                                style="-fx-background-color: #f4f4f4; -fx-text-fill: #777777;
                                       -fx-font-size: 12px; -fx-background-radius: 8;
                                       -fx-border-color: #e0e0e0; -fx-border-width: 1;
                                       -fx-padding: 9 16; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Table -->
                    <TableView fx:id="transactionTable"
                               VBox.vgrow="ALWAYS"
                               prefHeight="420"
                               style="-fx-background-color: transparent;
                                      -fx-border-color: transparent;
                                      -fx-table-cell-border-color: #f4f4f4;">
                        <columns>
                            <TableColumn fx:id="colDate"          text="Date"                   prefWidth="145"/>
                            <TableColumn fx:id="colResident"      text="Resident / Description"  prefWidth="185"/>
                            <TableColumn fx:id="colCategory"      text="Category"                prefWidth="120"/>
                            <TableColumn fx:id="colType"          text="Type"                    prefWidth="95"/>
                            <TableColumn fx:id="colAmount"        text="Amount"                  prefWidth="105"/>
                            <TableColumn fx:id="colPaymentMethod" text="Method"                  prefWidth="90"/>
                            <TableColumn fx:id="colStatus"        text="Status"                  prefWidth="95"/>
                            <TableColumn fx:id="colActions"       text="Actions"                 prefWidth="175"/>
                        </columns>
                        <placeholder>
                            <VBox alignment="CENTER" spacing="12" style="-fx-padding: 60;">
                                <Label text="📭" style="-fx-font-size: 40px;"/>
                                <Label text="No transactions found"
                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #cccccc;"/>
                                <Label text="Adjust your filters or add an expense to get started"
                                       style="-fx-font-size: 12px; -fx-text-fill: #dddddd;"/>
                            </VBox>
                        </placeholder>
                    </TableView>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>