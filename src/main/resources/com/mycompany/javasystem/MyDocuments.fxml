<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mycompany.javasystem.MyDocumentsController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #f4f4f4;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65"       
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24;">

            <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
                <Circle radius="18" fill="#2d2d2d"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="Barangay San Isidro"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="Resident Portal"
                           style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="🔔  Alerts" onAction="#goBackToDashboard"
                        style="-fx-background-color: #f4f4f4;
                               -fx-text-fill: #333333;
                               -fx-font-size: 12px;
                               -fx-background-radius: 20;
                               -fx-border-radius: 20;
                               -fx-border-color: #e0e0e0;
                               -fx-border-width: 1;
                               -fx-padding: 8 16;
                               -fx-cursor: hand;"/>

                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: #f4f4f4;
                             -fx-background-radius: 20;
                             -fx-border-radius: 20;
                             -fx-border-color: #e0e0e0;
                             -fx-border-width: 1;
                             -fx-padding: 6 16;">
                    <Circle radius="14" fill="#2d2d2d"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label text="Resident"
                               style="-fx-font-size: 12px; -fx-font-weight: bold;
                                      -fx-text-fill: #1a1a1a;"/>
                        <Label text="Resident"
                               style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>
                </HBox>

                <Button fx:id="logoutButton" text="← Logout" onAction="#handleLogout"
                    style="-fx-background-color: #ffffff;
                        -fx-text-fill: #555555;
                        -fx-font-size: 12px;
                        -fx-background-radius: 8;
                        -fx-border-radius: 8;
                        -fx-border-color: #e0e0e0;
                        -fx-border-width: 1;
                        -fx-padding: 8 16;
                        -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="220" prefHeight="700"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 1 0 0;
                     -fx-padding: 20 12;">

            <Label text="MAIN"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="🏠   Dashboard" maxWidth="Infinity"
                    onAction="#goBackToDashboard"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📄   My Documents" maxWidth="Infinity"
                    style="-fx-background-color: #2d2d2d;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📝   Request Document" maxWidth="Infinity"
                    onAction="#goToRequestDocument"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="SERVICES"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="💳   Payments" maxWidth="Infinity"
                    onAction="#goToPayments"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📢   My Complaints" maxWidth="Infinity"
                    onAction="#goToComplaints"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📣   Announcements" maxWidth="Infinity"
                    onAction="#goToAnnouncements"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="ACCOUNT"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="👤   My Profile" maxWidth="Infinity"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #f4f4f4;
                           -fx-background: #f4f4f4;
                           -fx-border-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 24;">

                <!-- Page Header -->
                <VBox spacing="8">
                    <Label text="My Documents"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="Track and manage all your document requests"
                           style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                </VBox>

                <!-- Documents Table Container -->
                <VBox style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1;
                             -fx-padding: 24;"
                      spacing="16">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Document Requests"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;
                                      -fx-text-fill: #1a1a1a;"
                               HBox.hgrow="ALWAYS"/>
                        <Button text="+ New Request" onAction="#goToRequestDocument"
                                style="-fx-background-color: #2d2d2d;
                                       -fx-text-fill: #ffffff;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-padding: 10 20;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Documents List -->
                    <VBox fx:id="documentsContainer" spacing="8">
                        <Label fx:id="loadingLabel" text="Loading documents..."
                               style="-fx-font-size: 14px; -fx-text-fill: #888888;"/>
                    </VBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>