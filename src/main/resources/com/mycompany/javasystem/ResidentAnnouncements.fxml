<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mycompany.javasystem.ResidentAnnouncementsController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #f4f4f4;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24;">
            <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
                <Circle radius="18" fill="#2d2d2d"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="Barangay San Isidro"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="Resident Portal"
                           style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="🔔  Alerts" onAction="#goToDashboard"
                        style="-fx-background-color: #f4f4f4;
                               -fx-text-fill: #333333;
                               -fx-font-size: 12px;
                               -fx-background-radius: 20;
                               -fx-border-radius: 20;
                               -fx-border-color: #e0e0e0;
                               -fx-border-width: 1;
                               -fx-padding: 8 16;
                               -fx-cursor: hand;"/>

                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: #f4f4f4;
                             -fx-background-radius: 20;
                             -fx-border-radius: 20;
                             -fx-border-color: #e0e0e0;
                             -fx-border-width: 1;
                             -fx-padding: 6 16;">
                    <Circle radius="14" fill="#2d2d2d"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label fx:id="residentNameLabel" text="Resident"
                               style="-fx-font-size: 12px; -fx-font-weight: bold;
                                      -fx-text-fill: #1a1a1a;"/>
                        <Label text="Resident"
                               style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>
                </HBox>
                <Button fx:id="logoutButton" text="← Logout" onAction="#handleLogout"
                        style="-fx-background-color: #ffffff;
                               -fx-text-fill: #555555;
                               -fx-font-size: 12px;
                               -fx-background-radius: 8;
                               -fx-border-radius: 8;
                               -fx-border-color: #e0e0e0;
                               -fx-border-width: 1;
                               -fx-padding: 8 16;
                               -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="220" prefHeight="700"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 1 0 0;
                     -fx-padding: 20 12;">

            <Label text="MAIN"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="🏠   Dashboard" maxWidth="Infinity"
                    onAction="#goToDashboard"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📄   My Documents" maxWidth="Infinity"
                    onAction="#goToMyDocuments"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📝   Request Document" maxWidth="Infinity"
                    onAction="#goToRequestDocument"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="SERVICES"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="💳   Payments" maxWidth="Infinity"
                    onAction="#goToPayments"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📢   My Complaints" maxWidth="Infinity"
                    onAction="#goToComplaints"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📣   Announcements" maxWidth="Infinity"
                    style="-fx-background-color: #2d2d2d;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="ACCOUNT"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="👤   My Profile" maxWidth="Infinity"
                    onAction="#goToProfile"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"
                    onMouseEntered="#handleMouseEntered"
                    onMouseExited="#handleMouseExited">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="16" VBox.vgrow="ALWAYS"
              style="-fx-padding: 24; -fx-background-color: #f4f4f4;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Announcements"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="Stay updated with barangay announcements"
                           style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
            </HBox>

            <!-- Summary Cards -->
            <HBox spacing="16">
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 10;
                             -fx-border-color: #eeeeee; -fx-border-width: 1; -fx-padding: 20;">
                    <Label text="Total" style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;">
                        <VBox.margin><Insets bottom="6"/></VBox.margin>
                    </Label>
                    <Label fx:id="totalLabel" text="0"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="All announcements"
                           style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 10;
                             -fx-border-color: #eeeeee; -fx-border-width: 1; -fx-padding: 20;">
                    <Label text="Emergency" style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;">
                        <VBox.margin><Insets bottom="6"/></VBox.margin>
                    </Label>
                    <Label fx:id="emergencyLabel" text="0"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="Active emergencies"
                           style="-fx-font-size: 11px; -fx-text-fill: #e53935;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 10;
                             -fx-border-color: #eeeeee; -fx-border-width: 1; -fx-padding: 20;">
                    <Label text="Urgent" style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;">
                        <VBox.margin><Insets bottom="6"/></VBox.margin>
                    </Label>
                    <Label fx:id="urgentLabel" text="0"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="Need attention"
                           style="-fx-font-size: 11px; -fx-text-fill: #f59e0b;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 10;
                             -fx-border-color: #eeeeee; -fx-border-width: 1; -fx-padding: 20;">
                    <Label text="Normal / Low" style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;">
                        <VBox.margin><Insets bottom="6"/></VBox.margin>
                    </Label>
                    <Label fx:id="normalLabel" text="0"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="General info"
                           style="-fx-font-size: 11px; -fx-text-fill: #4caf50;"/>
                </VBox>
            </HBox>

            <!-- Search and Filter -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <HBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 10;
                             -fx-border-color: #eeeeee; -fx-border-width: 1; -fx-padding: 10 16;">
                    <Label text="🔍 " style="-fx-font-size: 13px; -fx-text-fill: #aaaaaa;"/>
                    <TextField fx:id="searchField"
                               promptText="Search announcements..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: transparent;
                                      -fx-border-color: transparent;
                                      -fx-font-size: 13px; -fx-text-fill: #333333;"
                               onKeyReleased="#handleSearch"/>
                </HBox>
                <ComboBox fx:id="filterPriority" promptText="Filter by priority"
                          onAction="#handleFilter"
                          style="-fx-background-color: #ffffff; -fx-border-color: #eeeeee;
                                 -fx-border-width: 1; -fx-border-radius: 10;
                                 -fx-background-radius: 10; -fx-font-size: 12px; -fx-padding: 4;"/>
                <ComboBox fx:id="filterCategory" promptText="Filter by category"
                          onAction="#handleFilter"
                          style="-fx-background-color: #ffffff; -fx-border-color: #eeeeee;
                                 -fx-border-width: 1; -fx-border-radius: 10;
                                 -fx-background-radius: 10; -fx-font-size: 12px; -fx-padding: 4;"/>
                <Button text="Clear" onAction="#handleClearFilters"
                        style="-fx-background-color: #f4f4f4; -fx-text-fill: #555555;
                               -fx-font-size: 12px; -fx-background-radius: 8;
                               -fx-border-radius: 8; -fx-border-color: #e0e0e0;
                               -fx-border-width: 1; -fx-padding: 8 14; -fx-cursor: hand;"/>
            </HBox>

            <!-- Cards -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent;
                               -fx-background: transparent;
                               -fx-border-color: transparent;">
                <FlowPane fx:id="announcementsPane" hgap="16" vgap="16"
                          style="-fx-padding: 4;"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
