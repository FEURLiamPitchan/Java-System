<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mycompany.javasystem.ComplaintsController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #f4f4f4;"
            stylesheets="@style.css">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24;">
            <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
                <Circle radius="18" fill="#2d2d2d"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="Barangay San Isidro"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;"/>
                    <Label text="Management System"
                           style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <StackPane>
                    <Button fx:id="alertsButton" text="🔔  Alerts" onAction="#handleAlerts"
                            style="-fx-background-color: #f4f4f4;
                                   -fx-text-fill: #333333;
                                   -fx-font-size: 12px;
                                   -fx-background-radius: 20;
                                   -fx-border-radius: 20;
                                   -fx-border-color: #e0e0e0;
                                   -fx-border-width: 1;
                                   -fx-padding: 8 16;
                                   -fx-cursor: hand;"/>
                    <Label fx:id="alertBadge" text="0"
                           style="-fx-background-color: #e53935;
                                  -fx-text-fill: #ffffff;
                                  -fx-font-size: 9px;
                                  -fx-font-weight: bold;
                                  -fx-background-radius: 10;
                                  -fx-padding: 1 4;"
                           StackPane.alignment="TOP_RIGHT"
                           visible="false"/>
                </StackPane>
                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: #f4f4f4;
                             -fx-background-radius: 20;
                             -fx-border-radius: 20;
                             -fx-border-color: #e0e0e0;
                             -fx-border-width: 1;
                             -fx-padding: 6 16;">
                    <Circle radius="14" fill="#2d2d2d"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label text="Administrator"
                               style="-fx-font-size: 12px; -fx-font-weight: bold;
                                      -fx-text-fill: #1a1a1a;"/>
                        <Label text="Admin"
                               style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa;"/>
                    </VBox>
                </HBox>
                <Button fx:id="logoutButton" text="← Logout" onAction="#handleLogout"
                        style="-fx-background-color: #ffffff;
                               -fx-text-fill: #555555;
                               -fx-font-size: 12px;
                               -fx-background-radius: 8;
                               -fx-border-radius: 8;
                               -fx-border-color: #e0e0e0;
                               -fx-border-width: 1;
                               -fx-padding: 8 16;
                               -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="220" prefHeight="700"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8e8e8;
                     -fx-border-width: 0 1 0 0;
                     -fx-padding: 20 12;">

            <Label text="MAIN"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="🏠   Dashboard" maxWidth="Infinity"
                    onAction="#goToDashboard" focusTraversable="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="👥   Residents" maxWidth="Infinity"
                    onAction="#goToResidents" focusTraversable="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📄   Documents" maxWidth="Infinity"
                    onAction="#goToDocuments" focusTraversable="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="💳   Payments" maxWidth="Infinity"
                    onAction="#goToPayments" focusTraversable="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="    📁   Archive" maxWidth="Infinity"
                    onAction="#goToArchive" focusTraversable="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #777777; -fx-font-size: 12px;
                           -fx-background-radius: 8; -fx-padding: 9 16;
                           -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="COMMUNITY"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="📢   Complaints" maxWidth="Infinity"
                    onAction="#goToAnnouncements" focusTraversable="false"
                    style="-fx-background-color: #2d2d2d;
                           -fx-text-fill: #ffffff; -fx-font-size: 13px;
                           -fx-font-weight: bold; -fx-background-radius: 8;
                           -fx-padding: 11 16; -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="📣   Announcements" maxWidth="Infinity"
                    onAction="#goToAnnouncements" focusTraversable="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>

            <Label text="MANAGEMENT"
                   style="-fx-font-size: 10px; -fx-font-weight: bold;
                          -fx-text-fill: #bbbbbb; -fx-padding: 8 12 6 12;"/>

            <Button text="📊   Finance" maxWidth="Infinity"
                    onAction="#goToFinances" focusTraversable="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

            <Button text="⚙️   Admin" maxWidth="Infinity"
                    focusTraversable="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555555; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-padding: 11 16;
                           -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Button>

        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="16" VBox.vgrow="ALWAYS"
              style="-fx-padding: 24; -fx-background-color: #f4f4f4;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Complaints &amp; Incidents"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="Manage and respond to resident complaints"
                           style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
                <Button text="📄  Export PDF" onAction="#handleExportPDF"
                        style="-fx-background-color: #2d2d2d;
                               -fx-text-fill: #ffffff;
                               -fx-font-size: 12px;
                               -fx-background-radius: 8;
                               -fx-padding: 10 18;
                               -fx-cursor: hand;"/>
            </HBox>

            <!-- Summary Cards -->
            <HBox spacing="16">
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1; -fx-padding: 20;">
                    <Label text="Total Complaints"
                           style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;">
                        <VBox.margin><Insets bottom="6"/></VBox.margin>
                    </Label>
                    <Label fx:id="totalLabel" text="0"
                           style="-fx-font-size: 26px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="All time"
                           style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1; -fx-padding: 20;">
                    <Label text="Pending"
                           style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;">
                        <VBox.margin><Insets bottom="6"/></VBox.margin>
                    </Label>
                    <Label fx:id="pendingLabel" text="0"
                           style="-fx-font-size: 26px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="Awaiting review"
                           style="-fx-font-size: 11px; -fx-text-fill: #f59e0b;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1; -fx-padding: 20;">
                    <Label text="Under Review"
                           style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;">
                        <VBox.margin><Insets bottom="6"/></VBox.margin>
                    </Label>
                    <Label fx:id="underReviewLabel" text="0"
                           style="-fx-font-size: 26px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="Being processed"
                           style="-fx-font-size: 11px; -fx-text-fill: #1e88e5;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1; -fx-padding: 20;">
                    <Label text="Resolved"
                           style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;">
                        <VBox.margin><Insets bottom="6"/></VBox.margin>
                    </Label>
                    <Label fx:id="resolvedLabel" text="0"
                           style="-fx-font-size: 26px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a1a;">
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </Label>
                    <Label text="Completed"
                           style="-fx-font-size: 11px; -fx-text-fill: #4caf50;"/>
                </VBox>
            </HBox>

            <!-- Search, Filter, and Date Range -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <HBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 10;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1; -fx-padding: 10 16;">
                    <Label text="🔍 "
                           style="-fx-font-size: 13px; -fx-text-fill: #aaaaaa;"/>
                    <TextField fx:id="searchField"
                               promptText="Search by name or complaint ID..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: transparent;
                                      -fx-border-color: transparent;
                                      -fx-font-size: 13px; -fx-text-fill: #333333;"
                               onKeyReleased="#handleSearch"/>
                </HBox>
                <ComboBox fx:id="filterStatus" promptText="Filter by status"
                          onAction="#handleFilter"
                          style="-fx-background-color: #ffffff;
                                 -fx-border-color: #eeeeee; -fx-border-width: 1;
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-font-size: 12px; -fx-padding: 4;"/>
                <ComboBox fx:id="filterType" promptText="Filter by type"
                          onAction="#handleFilter"
                          style="-fx-background-color: #ffffff;
                                 -fx-border-color: #eeeeee; -fx-border-width: 1;
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-font-size: 12px; -fx-padding: 4;"/>
                <DatePicker fx:id="filterDateFrom" promptText="From date"
                            onAction="#handleFilter"
                            style="-fx-background-color: #ffffff;
                                   -fx-border-color: #eeeeee; -fx-border-width: 1;
                                   -fx-border-radius: 10; -fx-background-radius: 10;
                                   -fx-font-size: 12px;"/>
                <DatePicker fx:id="filterDateTo" promptText="To date"
                            onAction="#handleFilter"
                            style="-fx-background-color: #ffffff;
                                   -fx-border-color: #eeeeee; -fx-border-width: 1;
                                   -fx-border-radius: 10; -fx-background-radius: 10;
                                   -fx-font-size: 12px;"/>
                <Button text="Clear" onAction="#handleClearFilters"
                        style="-fx-background-color: #f4f4f4;
                               -fx-text-fill: #555555; -fx-font-size: 12px;
                               -fx-background-radius: 8; -fx-border-radius: 8;
                               -fx-border-color: #e0e0e0; -fx-border-width: 1;
                               -fx-padding: 8 14; -fx-cursor: hand;"/>
            </HBox>

            <!-- Table -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 10;
                         -fx-border-color: #eeeeee;
                         -fx-border-width: 1;">

                <!-- Table header with sort -->
                <HBox style="-fx-padding: 14 16;
                             -fx-border-color: #f0f0f0;
                             -fx-border-width: 0 0 1 0;
                             -fx-background-color: #fafafa;
                             -fx-background-radius: 10 10 0 0;">
                    <Button text="ID ↕" prefWidth="100" onAction="#sortById"
                            style="-fx-background-color: transparent;
                                   -fx-font-size: 11px; -fx-font-weight: bold;
                                   -fx-text-fill: #aaaaaa; -fx-cursor: hand;
                                   -fx-padding: 0; -fx-alignment: CENTER_LEFT;"/>
                    <Button text="COMPLAINANT ↕" prefWidth="180" onAction="#sortByName"
                            style="-fx-background-color: transparent;
                                   -fx-font-size: 11px; -fx-font-weight: bold;
                                   -fx-text-fill: #aaaaaa; -fx-cursor: hand;
                                   -fx-padding: 0; -fx-alignment: CENTER_LEFT;"/>
                    <Button text="INCIDENT TYPE ↕" prefWidth="160" onAction="#sortByType"
                            style="-fx-background-color: transparent;
                                   -fx-font-size: 11px; -fx-font-weight: bold;
                                   -fx-text-fill: #aaaaaa; -fx-cursor: hand;
                                   -fx-padding: 0; -fx-alignment: CENTER_LEFT;"/>
                    <Label text="LOCATION" prefWidth="160"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #aaaaaa;"/>
                    <Button text="DATE FILED ↕" prefWidth="120" onAction="#sortByDate"
                            style="-fx-background-color: transparent;
                                   -fx-font-size: 11px; -fx-font-weight: bold;
                                   -fx-text-fill: #aaaaaa; -fx-cursor: hand;
                                   -fx-padding: 0; -fx-alignment: CENTER_LEFT;"/>
                    <Button text="STATUS ↕" prefWidth="120" onAction="#sortByStatus"
                            style="-fx-background-color: transparent;
                                   -fx-font-size: 11px; -fx-font-weight: bold;
                                   -fx-text-fill: #aaaaaa; -fx-cursor: hand;
                                   -fx-padding: 0; -fx-alignment: CENTER_LEFT;"/>
                    <Label text="ACTION" prefWidth="150"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #aaaaaa;"/>
                </HBox>

                <!-- Scrollable Table rows -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent;
                                   -fx-background: transparent;
                                   -fx-border-color: transparent;">
                    <VBox fx:id="complaintsTableBody" style="-fx-padding: 0 16;">
                        <Label text="No complaints found."
                               style="-fx-font-size: 13px; -fx-text-fill: #aaaaaa;
                                      -fx-padding: 20 0;">
                            <VBox.margin><Insets top="20" bottom="20"/></VBox.margin>
                        </Label>
                    </VBox>
                </ScrollPane>

                <!-- Pagination -->
                <HBox alignment="CENTER" spacing="8"
                      style="-fx-padding: 12 16;
                             -fx-border-color: #f0f0f0;
                             -fx-border-width: 1 0 0 0;">
                    <Button text="← Prev" fx:id="prevButton" onAction="#handlePrev"
                            style="-fx-background-color: #f4f4f4;
                                   -fx-text-fill: #555555; -fx-font-size: 12px;
                                   -fx-background-radius: 8; -fx-border-radius: 8;
                                   -fx-border-color: #e0e0e0; -fx-border-width: 1;
                                   -fx-padding: 6 14; -fx-cursor: hand;"/>
                    <Label fx:id="pageLabel" text="Page 1 of 1"
                           style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
                    <Button text="Next →" fx:id="nextButton" onAction="#handleNext"
                            style="-fx-background-color: #f4f4f4;
                                   -fx-text-fill: #555555; -fx-font-size: 12px;
                                   -fx-background-radius: 8; -fx-border-radius: 8;
                                   -fx-border-color: #e0e0e0; -fx-border-width: 1;
                                   -fx-padding: 6 14; -fx-cursor: hand;"/>
                </HBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>